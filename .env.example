PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/plutonic
JWT_SECRET=change-this-in-production
CLIENT_URL=http://localhost:5173
# Public URL for WhatsApp links (must work on customer phones — use ngrok locally)
PUBLIC_URL=http://localhost:5173
BUFFER_MINUTES=30
WORK_START=08:00
WORK_END=18:00

# UltraMsg WhatsApp — https://docs.ultramsg.com/api/post/messages/chat
ULTRAMSG_INSTANCE_ID=instance181732
ULTRAMSG_TOKEN=your_ultramsg_token

# Meta WhatsApp Cloud API (optional fallback)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Stripe (optional — card payments disabled if missing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Places API — live ratings & reviews from Google Business Profile
# Enable "Places API" in Google Cloud Console, create an API key
GOOGLE_PLACES_API_KEY=
# Optional: exact Place ID (faster). Find via Google Maps → Share → embed or Places API
GOOGLE_PLACE_ID=
# Cache duration in ms (default 1 hour — reviews refresh hourly)
GOOGLE_PLACES_CACHE_MS=3600000

FIREBASE_PROJECT_ID=mkd-delivery-21550
# Option A: service account JSON file (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Option B: env vars (Render/Railway — paste from Firebase service account JSON)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
